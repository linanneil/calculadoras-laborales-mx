---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCalculator from "../components/ToolCalculator.astro";
import AdPlaceholder from "../components/AdPlaceholder.astro";
import { articlePages, pages, toolPages } from "../lib/pages";
import { SITE, updatedDate, withBase } from "../lib/site";

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const related = [...toolPages, ...articlePages].filter((item) => item.slug !== page.slug).slice(0, 4);
---

<BaseLayout title={page.title} description={page.description} slug={page.slug} faq={page.faqs} page={page}>
  <section class="hero">
    <div>
      <p class="eyebrow">{page.kind === "tool" ? "Calculadora gratuita" : page.kind === "legal" ? "Informacion del sitio" : "Guia laboral"}</p>
      <h1>{page.h1}</h1>
      <p class="lead">{page.intro}</p>
    </div>
    {page.tool ? <ToolCalculator tool={page.tool} /> : <AdPlaceholder />}
  </section>

  <section class="content">
    <article class="article-body">
      {page.sections.map((section) => (
        <section class="panel">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </section>
      ))}

      {page.slug === "contact" && (
        <section class="panel contact-card">
          <h2>Correo de contacto</h2>
          <p>
            Para correcciones, sugerencias editoriales o temas de privacidad, escribe a{" "}
            <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
          </p>
          <p class="muted">No podemos resolver casos laborales personales por correo.</p>
        </section>
      )}

      {page.formulaCards && (
        <section class="panel formulas">
          <h2>Formula de calculo</h2>
          <div class="formula-grid">
            {page.formulaCards.map((item) => (
              <article>
                <span>{item.label}</span>
                <code>{item.formula}</code>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
          <p class="muted">Las formulas muestran la logica base del estimador. El resultado final puede variar por contrato, prestaciones superiores, impuestos o documentos del caso.</p>
        </section>
      )}

      {page.faqs && (
        <section class="panel">
          <h2>Preguntas frecuentes</h2>
          {page.faqs.map((faq) => (
            <details>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </section>
      )}

      {page.sources && (
        <section class="panel sources">
          <h2>Fuentes oficiales consultadas</h2>
          <p>Usamos estas referencias como base editorial. El contenido se resume para hacerlo facil de entender.</p>
          <ul>
            {page.sources.map((source) => (
              <li><a href={source.url} target="_blank" rel="noreferrer">{source.label}</a></li>
            ))}
          </ul>
        </section>
      )}

      <section class="panel disclaimer">
        <h2>Aviso importante</h2>
        <p>
          Estos calculos son estimaciones informativas para Mexico y fueron actualizados el {updatedDate}. No sustituyen asesoria legal, fiscal o contable.
        </p>
      </section>
    </article>
    <aside>
      <AdPlaceholder />
      <div class="panel related">
        <h2>Tambien te puede servir</h2>
        {related.map((item) => <a href={withBase(`/${item.slug}`)}>{item.h1}</a>)}
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  details {
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }

  summary {
    cursor: pointer;
    font-weight: 800;
  }

  aside {
    display: grid;
    gap: 16px;
  }

  .related {
    display: grid;
    gap: 10px;
  }

  .related h2 {
    font-size: 1.2rem;
  }

  .sources ul {
    margin: 10px 0 0;
    padding-left: 20px;
  }

  .sources li {
    margin: 8px 0;
  }

  .contact-card a {
    font-weight: 800;
  }

  .formulas h2 {
    margin-bottom: 14px;
  }

  .formula-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .formula-grid article {
    display: grid;
    gap: 8px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface-muted);
  }

  .formula-grid span {
    font-weight: 800;
  }

  .formula-grid code {
    display: block;
    padding: 10px;
    border-radius: 6px;
    background: white;
    color: var(--accent-dark);
    white-space: normal;
  }

  .formula-grid p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .formula-grid {
      grid-template-columns: 1fr;
    }
  }

  .disclaimer {
    border-color: color-mix(in srgb, var(--warning), var(--line) 65%);
  }
</style>
