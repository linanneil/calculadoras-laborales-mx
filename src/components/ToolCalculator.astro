---
import type { ToolKind } from "../lib/pages";
import { GENERAL_MINIMUM_WAGE_2026 } from "../lib/labor";

type Props = {
  tool: ToolKind;
};

const { tool } = Astro.props;
const today = "2026-06-15";
---

<section class="tool-panel" data-tool={tool}>
  <div class="tool-heading">
    <h2>{tool === "finiquito" ? "Calculadora de finiquito" : tool === "liquidacion" ? "Calculadora de liquidacion" : tool === "aguinaldo" ? "Calculadora de aguinaldo" : tool === "vacaciones" ? "Calculadora de vacaciones" : "Calculadora de SDI"}</h2>
    <span>Vista rapida</span>
  </div>
  <div class="tool-body">
  <form class="calculator-form">
    <label>
      Salario diario bruto
      <span class="input-shell"><i class="ri-money-dollar-circle-line" aria-hidden="true"></i><input name="dailySalary" type="number" min="1" step="0.01" value="500" inputmode="decimal" required /></span>
    </label>
    <label>
      Fecha de ingreso
      <span class="input-shell"><i class="ri-calendar-line" aria-hidden="true"></i><input name="startDate" type="date" value="2024-01-15" required /></span>
    </label>
    <label>
      Fecha de salida o calculo
      <span class="input-shell"><i class="ri-calendar-check-line" aria-hidden="true"></i><input name="endDate" type="date" value={today} required /></span>
    </label>
    {tool !== "aguinaldo" && tool !== "vacaciones" && tool !== "sdi" && (
      <label>
        Dias de salario pendientes
        <span class="input-shell"><i class="ri-time-line" aria-hidden="true"></i><input name="pendingSalaryDays" type="number" min="0" step="1" value="5" inputmode="numeric" /></span>
      </label>
    )}
    {tool === "liquidacion" && (
      <label>
        Salario minimo diario usado para tope
        <span class="input-shell"><i class="ri-scales-3-line" aria-hidden="true"></i><input name="minimumWage" type="number" min="1" step="0.01" value={GENERAL_MINIMUM_WAGE_2026} inputmode="decimal" /></span>
      </label>
    )}
    {tool === "sdi" && (
      <label>
        Anos de antiguedad completos
        <span class="input-shell"><i class="ri-briefcase-line" aria-hidden="true"></i><input name="years" type="number" min="1" step="1" value="1" inputmode="numeric" /></span>
      </label>
    )}
    <details>
      <summary>Opciones avanzadas</summary>
      <p>Usa importes brutos y fechas reales para mejorar la estimacion.</p>
    </details>
    <button class="button" type="submit">Calcular estimacion</button>
  </form>
  <div class="result" aria-live="polite">
    <p class="muted">Completa los datos y calcula para ver el desglose.</p>
  </div>
  </div>
</section>

<script>
  import {
    calculateAguinaldo,
    calculateFiniquito,
    calculateIntegratedDailySalary,
    calculateLiquidation,
    calculateVacations,
  } from "../lib/labor";
  import { formatMxn } from "../lib/site";

  document.querySelectorAll<HTMLElement>("[data-tool]").forEach((panel) => {
    const form = panel.querySelector<HTMLFormElement>("form");
    const result = panel.querySelector<HTMLElement>(".result");
    if (!form || !result) return;

    const render = () => {
      const data = new FormData(form);
      const input = {
        dailySalary: Number(data.get("dailySalary")),
        startDate: String(data.get("startDate")),
        endDate: String(data.get("endDate")),
        pendingSalaryDays: Number(data.get("pendingSalaryDays") ?? 0),
        minimumWage: Number(data.get("minimumWage") ?? 315.04),
      };
      const tool = panel.dataset.tool;

      if (tool === "sdi") {
        const years = Number(data.get("years") ?? 1);
        const total = calculateIntegratedDailySalary(input.dailySalary, years);
        result.innerHTML = `
          <h3>Resultado estimado</h3>
          <p class="total">${formatMxn(total)}</p>
          <p class="muted">Salario diario integrado estimado con prestaciones minimas.</p>
          <div class="notice"><i class="ri-information-line" aria-hidden="true"></i><span>Resultado estimado. No sustituye asesoria legal.</span></div>
        `;
        return;
      }

      const calculated =
        tool === "liquidacion"
          ? calculateLiquidation(input)
          : tool === "aguinaldo"
            ? calculateAguinaldo(input)
            : tool === "vacaciones"
              ? calculateVacations(input)
              : calculateFiniquito(input);

      const rows = calculated.items
        .map((item) => `<li><span>${item.label}</span><strong>${formatMxn(item.amount)}</strong></li>`)
        .join("");

      result.innerHTML = `
        <h3>Resultado estimado</h3>
        <p class="total">${formatMxn(calculated.total)}</p>
        <ul>${rows}</ul>
        <p class="muted">${calculated.daysWorked} dias considerados, ${calculated.yearsWorked} anos completos.</p>
        <div class="notice"><i class="ri-information-line" aria-hidden="true"></i><span>Resultado estimado. Los montos pueden variar segun tu caso particular.</span></div>
      `;
    };

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      render();
    });

    render();
  });
</script>

<style>
  .tool-panel {
    overflow: hidden;
    min-width: 0;
  }

  .tool-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 22px;
    border-bottom: 1px solid var(--line);
  }

  .tool-heading h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .tool-heading span {
    flex: 0 0 auto;
    padding: 5px 10px;
    border-radius: 7px;
    background: var(--warning-soft);
    color: var(--warning);
    font-weight: 800;
    font-size: 0.82rem;
  }

  .tool-body {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(250px, 1.1fr);
  }

  .calculator-form {
    display: grid;
    align-content: start;
    gap: 18px;
    padding: 28px 22px;
    border-right: 1px solid var(--line);
  }

  label {
    display: grid;
    gap: 8px;
    color: var(--text);
    font-weight: 700;
    font-size: 0.9rem;
  }

  input {
    width: 100%;
    min-width: 0;
    min-height: 44px;
    border: 0;
    padding: 10px 10px 10px 0;
    color: var(--text);
    font: inherit;
    background: transparent;
    outline: none;
  }

  .input-shell {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    align-items: center;
    min-height: 48px;
    border: 1px solid var(--line-strong);
    border-radius: 6px;
    background: white;
  }

  .input-shell i {
    justify-self: center;
    color: var(--accent-dark);
    font-size: 1.12rem;
  }

  details {
    color: var(--accent-dark);
    font-size: 0.9rem;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
  }

  button {
    border: 0;
    cursor: pointer;
  }

  .result {
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    min-width: 0;
  }

  :global(.tool-panel .result .total) {
    margin: 8px 0 18px;
    font-size: clamp(2.2rem, 4vw, 3.1rem);
    line-height: 1.1;
    font-weight: 800;
    color: var(--accent-dark);
    letter-spacing: -0.04em;
  }

  :global(.tool-panel .result ul) {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 10px 0 18px;
    list-style: none;
  }

  :global(.tool-panel .result li) {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 9px 0;
    border-bottom: 1px solid var(--line);
  }

  :global(.tool-panel .result li strong) {
    white-space: nowrap;
  }

  :global(.tool-panel .result .notice) {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-top: auto;
    padding: 14px;
    border: 1px solid #b8d2c4;
    border-radius: 6px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    font-size: 0.88rem;
    font-weight: 700;
  }

  :global(.tool-panel .result .notice i) {
    font-size: 1.2rem;
    flex: 0 0 auto;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .tool-body {
      grid-template-columns: 1fr;
    }

    .calculator-form {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
