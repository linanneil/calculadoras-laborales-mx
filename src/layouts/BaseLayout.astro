---
import "remixicon/fonts/remixicon.css";
import { SITE, updatedDate } from "../lib/site";
import { legalPages, toolPages } from "../lib/pages";

type Props = {
  title: string;
  description: string;
  slug?: string;
  faq?: { question: string; answer: string }[];
};

const { title, description, slug = "", faq = [] } = Astro.props;
const canonical = new URL(`/${slug}`.replace(/\/$/, ""), Astro.site ?? SITE.url).toString();
const faqJson =
  faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      }
    : null;
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {faqJson && <script type="application/ld+json" set:html={JSON.stringify(faqJson)} />}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${SITE.name} inicio`}>
        <span class="brand-mark">MX</span>
        <span>{SITE.name}</span>
      </a>
      <nav aria-label="Navegacion principal">
        {toolPages.slice(0, 4).map((page) => (
          <a href={`/${page.slug}`}>
            {page.tool === "finiquito" ? "Finiquito" : page.tool === "liquidacion" ? "Liquidacion" : page.tool === "aguinaldo" ? "Aguinaldo" : "Vacaciones"}
          </a>
        ))}
      </nav>
      <div class="header-trust" aria-label="Caracteristicas del sitio">
        <span><i class="ri-question-line" aria-hidden="true"></i> Guias y articulos</span>
        <span><i class="ri-shield-check-line" aria-hidden="true"></i> 100% Gratis</span>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{SITE.name}</strong>
        <p>Estimaciones laborales para Mexico. Ultima actualizacion: {updatedDate}.</p>
      </div>
      <nav aria-label="Paginas legales">
        {legalPages.map((page) => <a href={`/${page.slug}`}>{page.h1}</a>)}
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #fbfcfb;
    --surface: #ffffff;
    --surface-soft: #f1f7f3;
    --surface-muted: #f7f9f8;
    --text: #121a18;
    --muted: #52615b;
    --line: #d8dfdc;
    --line-strong: #c4cfca;
    --accent: #005f4b;
    --accent-dark: #00483b;
    --accent-soft: #e7f2ec;
    --warning: #8f5b16;
    --warning-soft: #fbefe6;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  a {
    color: var(--accent-dark);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  i {
    display: inline-block;
    line-height: 1;
  }

  .site-header,
  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 28px;
    align-items: center;
    max-width: 1340px;
    margin: 0 auto;
    padding: 14px 32px;
  }

  .site-header {
    min-height: 84px;
    border-bottom: 1px solid var(--line);
    background: rgb(255 255 255 / 0.92);
    backdrop-filter: blur(10px);
  }

  .site-header nav,
  .site-footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 26px;
    font-size: 0.94rem;
  }

  .site-header nav {
    flex: 1;
    justify-content: center;
    font-weight: 700;
    flex-wrap: nowrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    color: var(--text);
    font-weight: 800;
    font-size: 1.32rem;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 0;
    background: white;
    border: 3px solid var(--accent-dark);
    color: var(--accent-dark);
    font-size: 1.5rem;
    letter-spacing: 0;
  }

  .header-trust {
    display: flex;
    gap: 18px;
    align-items: center;
    color: var(--text);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .header-trust span {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }

  .header-trust i {
    color: var(--accent-dark);
    font-size: 1.2rem;
  }

  main {
    max-width: 1340px;
    margin: 0 auto;
    padding: 0 32px 34px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(560px, 1.02fr);
    gap: 72px;
    align-items: center;
    padding: 64px 0 40px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 7px 12px;
    border: 1px solid #a9cabb;
    border-radius: 8px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }

  h1,
  h2,
  h3 {
    line-height: 1.18;
    margin: 0 0 14px;
  }

  h1 {
    font-size: clamp(2.35rem, 5.7vw, 4.7rem);
    letter-spacing: -0.04em;
    max-width: 11ch;
  }

  h2 {
    font-size: clamp(1.25rem, 2vw, 1.8rem);
    letter-spacing: -0.02em;
  }

  p {
    margin: 0 0 14px;
  }

  .lead {
    max-width: 64ch;
    color: var(--muted);
    font-size: 1.15rem;
    line-height: 1.65;
  }

  .panel,
  .tool-panel,
  .ad-placeholder {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 7px;
    box-shadow: none;
  }

  .panel {
    padding: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0;
    margin: 22px 0 34px;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 7px;
    overflow: hidden;
  }

  .card {
    min-height: 150px;
    padding: 22px;
    background: var(--surface);
    border: 0;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-radius: 0;
  }

  .card p {
    color: var(--muted);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 58px;
    padding: 14px 22px;
    border-radius: 4px;
    background: var(--accent);
    color: white;
    font-weight: 700;
    font-size: 1rem;
  }

  .button:hover {
    background: var(--accent-dark);
    text-decoration: none;
  }

  .content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 28px;
    align-items: start;
    padding-top: 34px;
  }

  .article-body {
    display: grid;
    gap: 18px;
  }

  .ad-placeholder {
    padding: 28px;
    color: var(--muted);
    font-size: 0.92rem;
    background: var(--surface-muted);
  }

  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    align-items: flex-start;
    max-width: 1340px;
  }

  @media (max-width: 1040px) {
    .site-header {
      flex-wrap: wrap;
    }

    .site-header nav {
      justify-content: flex-start;
      order: 3;
      width: 100%;
      flex-wrap: wrap;
    }

    .header-trust {
      margin-left: auto;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 780px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
      padding: 16px 20px;
    }

    .site-header nav {
      order: initial;
      gap: 10px 18px;
    }

    .header-trust {
      margin-left: 0;
      flex-wrap: wrap;
    }

    main {
      padding: 0 20px 28px;
    }

    .hero,
    .content {
      grid-template-columns: 1fr;
      padding-top: 32px;
    }

    h1 {
      max-width: 100%;
      font-size: 2.35rem;
      letter-spacing: -0.03em;
    }
  }
</style>
